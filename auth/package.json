{
  "name": "auth-module",
  "version": "1.0.0",
  "description": "User authentication module with JWT and OAuth support",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && ts-node server.ts",
    "dev:frontend": "cd frontend && npm start",
    "build:backend": "cd backend && tsc",
    "build:frontend": "cd frontend && npm run build",
    "test": "jest --coverage",
    "test:unit": "jest auth/tests/unit",
    "test:integration": "jest auth/tests/integration",
    "lint": "eslint auth/**/*.{ts,tsx}"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "better-sqlite3": "^9.6.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-google-oauth20": "^2.0.0",
    "passport-github2": "^0.1.12",
    "express-session": "^1.17.3",
    "uuid": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/better-sqlite3": "^7.6.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-github2": "^1.2.8",
    "@types/express-session": "^1.17.10",
    "@types/uuid": "^9.0.7",
    "@types/react": "^18.2.39",
    "@types/react-dom": "^18.2.17",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^6.0.2",
    "typescript": "^5.3.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1"
  }
